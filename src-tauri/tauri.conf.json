{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZError",
  "version": "2.2.6",
  "identifier": "com.zerror.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "capabilities": ["default", "url-content", "file-info"]
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": "ZError",
      "entitlements": null,
      "signingIdentity": null
    },
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": null
    }
  },
  "plugins": {}
}
